            "parameters": {
                "jsCode": "// Extract the latest post and URN\nconst items = $input.all().map(item => item.json);\nif (!items || items.length === 0) return [];\n\nconst latestPost = items[0];\n\n// URL field\nconst url = latestPost.url || latestPost.postUrl || latestPost.articleUrl || latestPost.shareUrl || \"\";\n\n// ---- URN extraction ----\n// Apify returns urn as an OBJECT: { activity_urn, share_urn, ugcPost_urn }\n// full_urn is a TOP-LEVEL field on latestPost (not inside urn object)\nlet urn = \"\";\nconst urnObj = latestPost.urn;\n// 1. Prefer top-level full_urn if it points to ugcPost (most reliable)\nif (latestPost.full_urn && latestPost.full_urn.startsWith(\"urn:li:ugcPost:\")) {\n  urn = latestPost.full_urn;\n} else if (urnObj && typeof urnObj === \"object\") {\n  // 2. Prefer ugcPost_urn — LinkedIn Comments API requires this, NOT activity_urn\n  if (urnObj.ugcPost_urn) urn = \"urn:li:ugcPost:\" + urnObj.ugcPost_urn;\n  else if (urnObj.share_urn) urn = \"urn:li:share:\" + urnObj.share_urn;\n  // Only fall back to activity_urn as last resort (may cause 400 errors)\n  else if (urnObj.activity_urn) urn = \"urn:li:activity:\" + urnObj.activity_urn;\n} else if (typeof urnObj === \"string\" && urnObj) {\n  urn = urnObj;\n}\n// Also accept full_urn even if not ugcPost (e.g. share)\nif (!urn && latestPost.full_urn) urn = latestPost.full_urn;\n\n// If still empty, try extracting from post URL\nif (!urn) {\n  const urnMatch = url.match(/(urn:li:[a-zA-Z]+:[0-9]+)/);\n  if (urnMatch) urn = urnMatch[1];\n}\n\n// If urn is a bare number, prefix with urn:li:activity:\nif (urn && /^[0-9]+$/.test(urn)) {\n  urn = \"urn:li:activity:\" + urn;\n}\n\n// ---- Author extraction ----\n// Avoid \"undefined undefined\" by checking each field exists before using\nconst authorRaw = latestPost.author;\nlet author = \"\";\nif (typeof authorRaw === \"string\") {\n  author = authorRaw;\n} else if (authorRaw && typeof authorRaw === \"object\") {\n  const first = authorRaw.firstName || authorRaw.first_name || \"\";\n  const last = authorRaw.lastName || authorRaw.last_name || \"\";\n  author = authorRaw.name || [first, last].filter(Boolean).join(\" \") || \"\";\n}\nif (!author) author = latestPost.actorName || $('Split In Batches17').item.json.username || \"\";\n\nreturn {\n  json: {\n    post_text: latestPost.text || latestPost.commentary || latestPost.description || latestPost.content || \"\",\n    author: author,\n    post_url: url,\n    urn: urn\n  }\n};\n"
            },
